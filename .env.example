# =========================================
# Database
# =========================================
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/myappdb"

# =========================================
# Auth.js (NextAuth v5)
# =========================================
AUTH_SECRET="your_super_secret_here"
AUTH_URL="http://localhost:3000"

# GitHub OAuth
AUTH_GITHUB_ID="your_github_client_id"
AUTH_GITHUB_SECRET="your_github_client_secret"

# =========================================
# Public keys (exposed to browser)
# =========================================
NEXT_PUBLIC_PUBLISHABLE_KEY="your_public_key_here"

# =========================================
# Optional integrations
# =========================================
OPEN_AI_API_KEY="your_openai_key_here"